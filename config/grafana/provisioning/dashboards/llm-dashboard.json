{
  "dashboard": {
    "title": "LLM Load Balancer",
    "uid": "llm-load-balancer",
    "tags": ["llm", "load-balancer"],
    "timezone": "browser",
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "Worker Health Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "llm_worker_status",
            "legendFormat": "{{worker_id}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "options": {"0": {"text": "UNHEALTHY", "color": "red"}}},
              {"type": "value", "options": {"1": {"text": "HEALTHY", "color": "green"}}}
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "red"},
                {"value": 1, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Active Connections",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "sum(llm_worker_connections)"
          }
        ]
      },
      {
        "id": 3,
        "title": "Queue Size",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "llm_queue_size"
          }
        ]
      },
      {
        "id": 4,
        "title": "Requests/Second",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(llm_requests_total[5m]))"
          }
        ]
      },
      {
        "id": 5,
        "title": "Latency by Worker (p50, p95, p99)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(llm_request_latency_seconds_bucket[5m])) by (le, worker_id))",
            "legendFormat": "p50 - {{worker_id}}"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(llm_request_latency_seconds_bucket[5m])) by (le, worker_id))",
            "legendFormat": "p95 - {{worker_id}}"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(llm_request_latency_seconds_bucket[5m])) by (le, worker_id))",
            "legendFormat": "p99 - {{worker_id}}"
          }
        ]
      },
      {
        "id": 6,
        "title": "Active Connections by Worker",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "llm_worker_connections",
            "legendFormat": "{{worker_id}}"
          }
        ]
      },
      {
        "id": 7,
        "title": "Request Rate by Worker",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "sum by (worker_id) (rate(llm_requests_total[1m]))",
            "legendFormat": "{{worker_id}}"
          }
        ]
      },
      {
        "id": 8,
        "title": "Circuit Breaker State",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "targets": [
          {
            "expr": "llm_circuit_breaker_state",
            "legendFormat": "{{worker_id}}"
          }
        ]
      },
      {
        "id": 9,
        "title": "Dead Letter Queue Size",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 20},
        "targets": [
          {
            "expr": "llm_dead_letter_size"
          }
        ]
      },
      {
        "id": 10,
        "title": "Total Requests (Success vs Failed)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 18, "x": 6, "y": 20},
        "targets": [
          {
            "expr": "sum by (status) (rate(llm_requests_total[5m]))",
            "legendFormat": "{{status}}"
          }
        ]
      }
    ]
  },
  "overwrite": true
}
