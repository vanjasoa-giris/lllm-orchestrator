FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY orchestrator/ /app/orchestrator/
COPY config/ /app/config/
COPY webui/ /app/webui/
COPY orchestrator_entrypoint_production.py /app/orchestrator_entrypoint.py

ENV PORT=8000
ENV CONFIG_PATH=/app/config/workers.docker.yaml

EXPOSE 8000

CMD ["python", "-m", "uvicorn", "orchestrator.main_production_final:app", "--host", "0.0.0.0", "--port", "8000"]
